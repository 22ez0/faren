# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/faren

# ─── API Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Auth ────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-64-char-string

# ─── Admin Panel (faren.com.br/keefaren) ─────────────────────────
ADMIN_LOGIN=keefaren
ADMIN_PASSWORD=change-me-strong-password
ADMIN_SECRET=change-me-to-a-random-64-char-string

# ─── CORS ────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://faren.com.br,https://www.faren.com.br

# ─── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ─── Security ────────────────────────────────────────────────────
ENABLE_BOT_BLOCKING=true

# ─── Frontend (build time) ───────────────────────────────────────
BASE_PATH=/
VITE_API_URL=https://faren-api.onrender.com
