modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx -y concurrently -k -n API,WEB -c blue,magenta \"PORT=8080 pnpm --filter @workspace/api-server run dev\" \"PORT=21395 BASE_PATH=/ pnpm --filter @workspace/faren run dev\""
waitForPort = 21395

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 21395
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
ADMIN_LOGIN = "keefaren"
ADMIN_PASSWORD = "Hungria2021@"
ADMIN_SECRET = "dev-admin-faren-replit-u3i7lafpx3ro6hjv5i4jpr"
ENABLE_BOT_BLOCKING = "false"
NODE_ENV = "development"
BASE_PATH = "/"
VITE_API_URL = ""
CORS_ALLOWED_ORIGINS = "*"
