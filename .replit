modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 21395
externalPort = 3000

[[ports]]
localPort = 21396
externalPort = 3001

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
ADMIN_LOGIN = "keefaren"
ADMIN_PASSWORD = "Hungria2021@"
ADMIN_SECRET = "dev-admin-faren-replit-u3i7lafpx3ro6hjv5i4jpr"
ENABLE_BOT_BLOCKING = "false"
NODE_ENV = "development"
BASE_PATH = "/"
VITE_API_URL = "https://faren-api-wn1z.onrender.com"
CORS_ALLOWED_ORIGINS = "*"
